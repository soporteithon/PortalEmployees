# --- SEGURIDAD ---
# Ignorar archivos de variables de entorno en cualquier carpeta
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.*

# --- DEPENDENCIAS ---
# No subimos las librerías, cada quien las descarga con 'npm install'
node_modules/
**/node_modules/

# --- COMPILACIÓN ---
# Ignorar carpetas de archivos generados automáticamente
dist/
build/
**/dist/
**/build/

# --- EDITOR ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# --- LOGS ---
*.log
npm-debug.log*
yarn-debug.log*
